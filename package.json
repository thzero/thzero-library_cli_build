    "@thzero/library_common_service": "^0.18",
    "@thzero/library_server_logger_pino": "^0.18",
    "@thzero/library_server_logger_winston": "^0.18",
    "await-spawn": "^4.0.2",
    "config": "^4.4.1",
    "cross-spawn": "^7.0.6",
    "github-api": "^3.4.0",
    "isomorphic-unfetch": "^4.0.2",
    "minimist": "^1.2.8",
    "npm-check-updates": "^22.2.0",
    "pino-pretty": "^13.1.3",
    "simple-git": "^3.36.0"
  }
