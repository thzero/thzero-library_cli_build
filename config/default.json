{
	"app": {
        "logging": {
            "level": null,
            "prettify": true
        },
		"buildTypes": [
			{
				"tag": "dependencyCheck",
				"actions": [
					"clean",
					"clone",
					"dependencyCheck"
				],
				"plugins": [
					"dependencyCheckAccumulate"
				]
			},
			{
				"tag": "license",
				"actions": [
					"clean",
					"clone",
					"license",
					"version",
					"commit",
					"merge",
					"publish"
				]
			},
			{
				"tag": "publishOnly",
				"actions": [
					"publishOnly"
				]
			},
			{
				"tag": "pullRequestOnly",
				"actions": [
					"clean",
					"pull"
				]
			},
			{
				"tag": "standard",
				"actions": [
					"clean",
					"clone",
					"dependencyUpdate",
					"status",
					"version",
					"commit",
					"merge",
					"publish"
				]
			},
			{
				"tag": "sync",
				"actions": [
					"clean",
					"clone",
					"copy",
					"status",
					"version",
					"commit",
					"merge",
					"publish"
				]
			},
			{
				"tag": "versionOnly",
				"actions": [
					"clean",
					"clone",
					"versionAlways",
					"commit",
					"merge",
					"publish"
				]
			}
		]
    }
}